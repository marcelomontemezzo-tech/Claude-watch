{
  "name": "claude-watch",
  "version": "0.1.0",
  "description": "Real-time supervision UI for Claude Code sessions. Monitor tokens, agents, and parallel workflow on a second monitor.",
  "type": "module",
  "bin": {
    "claude-watch": "./bin/claude-watch.mjs"
  },
  "scripts": {
    "dev": "concurrently -n server,ui -c cyan,magenta \"npm:dev:server\" \"npm:dev:ui\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:ui": "vite",
    "build": "vite build && tsc -p server/tsconfig.json",
    "start": "node bin/claude-watch.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p server/tsconfig.json"
  },
  "files": [
    "bin",
    "dist",
    "server-dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@xyflow/react": "^12.4.4",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "commander": "^13.1.0",
    "dagre": "^0.8.5",
    "express": "^5.0.1",
    "lucide-react": "^0.469.0",
    "open": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/dagre": "^0.7.52",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
